*.c4d
*.c4d.bak

# Uncompressed master models (configurator uses hk_compressed.glb only)
hk_mainmodeling_assemble.glb
hk_mainmodeling_assemble.gltf
hk_mainmodeling_assemble.bin
hk_mainmodeling.glb
hk_mainmodeling.gltf

# Render bundles
*_dropandrender*
lookdev-preset*.zip

# Adobe After Effects project files
*.aep
*.aep.bak

# Archive files
*.rar
*.7z

# ===== OS files =====
.DS_Store
Thumbs.db
desktop.ini

# ===== Editor files =====
*.swp
.vscode/
.idea/

